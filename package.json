{
  "name": "scaffoldx",
  "version": "1.0.0",
  "description": "CLI to scaffold projects from remotely configured templates",
  "license": "MIT",
  "author": "",
  "keywords": [
    "cli",
    "scaffold",
    "template",
    "degit",
    "scaffoldx"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
